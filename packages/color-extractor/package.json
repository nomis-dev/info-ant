{
  "name": "@info-ant/color-extractor",
  "version": "1.0.0",
  "description": "Extract a website's color palette and design tokens without a headless browser. Pure Node, drops into any Next.js app or runs standalone.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "color",
    "palette",
    "color-extraction",
    "theme-color",
    "design-tokens",
    "og-image",
    "vibrant",
    "nextjs",
    "ssrf"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/cli.js"
  ],
  "bin": {
    "colorextractor": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "import": "./dist/handler.js",
      "default": "./dist/handler.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "node --import tsx --test test/*.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "design": "node --import tsx scripts/design.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "node-vibrant": "^4.0.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
